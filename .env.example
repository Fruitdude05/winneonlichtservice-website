# Web3Forms Access Key für Kontaktformular-E-Mails
# Kostenlos einrichten unter: https://web3forms.com
# 1. E-Mail info@winneonlichtservice.de eintragen
# 2. Access Key kopieren und hier einfügen
# 3. Dev-Server neu starten

VITE_WEB3FORMS_ACCESS_KEY=

# OpenAI für KI-Chat (serverseitig — nicht VITE_ prefix)
# https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Web3Forms für E-Mail-Benachrichtigungen (Dave-Chat + Kontaktformular)
# Lokal: VITE_ für Frontend-Build. Live zusätzlich in public_html/api/openai-config.php
VITE_WEB3FORMS_ACCESS_KEY=
WEB3FORMS_ACCESS_KEY=

# Optional: WhatsApp-Benachrichtigung bei Chat (CallMeBot)
# Lokal: VITE_ für Dev. Live optional in openai-config.php als CALLMEBOT_API_KEY
VITE_CALLMEBOT_API_KEY=
CALLMEBOT_API_KEY=
