DirectoryIndex index.html

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # PHP-API nie an die SPA weiterleiten
  RewriteRule ^api/ - [L]

  # Statische Dateien und Ordner (z. B. /kontakt/index.html) unverändert ausliefern
  RewriteRule ^index\.html$ - [L]
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # SPA-Fallback nur für unbekannte Pfade
  RewriteRule . /index.html [L]
</IfModule>
